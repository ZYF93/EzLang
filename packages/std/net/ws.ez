// std/net/ws.ez - WebSocket 标准库
// 依赖: EzLang 标准库封装层（C/JS）

extern "@std/native/net/ws.c" for linux;
extern "@std/native/net/ws.c" for macos;
extern "@std/native/net/ws.c" for windows;
extern "@std/native/net/ws.c" for android;
extern "@std/native/net/ws.c" for ios;
extern "@std/emcc/net/ws.js" for emcc;

export struct WsConn {
    handle: I64;
};

// 原生目标仅支持 ws:// 握手和基础单帧消息；wss://、分片帧和 emcc 同步 WebSocket 明确不支持。
export declare const wsConnect: (url: Str) => WsConn?;
export declare const wsSend: (conn: WsConn, data: Blob) => I64;
export declare const wsRecv: (conn: WsConn, maxBytes: I64) => Blob?;
export declare const wsClose: (conn: WsConn) => Bool;
