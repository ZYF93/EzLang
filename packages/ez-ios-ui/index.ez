export declare const getText: (node: Node) => Str;
export declare const setAttributedText: (node: Node, html: Str) => Void;
export declare const setFont: (node: Node, name: Str, size: F32) => Void;
export declare const setSystemFont: (node: Node, size: F32, weight: F32) => Void;
export declare const setTextColor: (node: Node, color: Color) => Void;
export declare const setTextAlign: (node: Node, align: I32) => Void;
export declare const setNumberOfLines: (node: Node, n: I32) => Void;
export declare const setLineBreakMode: (node: Node, mode: I32) => Void;
export declare const setPlaceholder: (node: Node, text: Str) => Void;
export declare const setKeyboardType: (node: Node, type_: I32) => Void;
export declare const setSecureEntry: (node: Node, secure: Bool) => Void;
export declare const setReturnKeyType: (node: Node, type_: I32) => Void;
export declare const setBackgroundColor: (node: Node, color: Color) => Void;
export declare const setAlpha: (node: Node, alpha: F32) => Void;
export declare const setHidden: (node: Node, hidden: Bool) => Void;
export declare const setUserInteraction: (node: Node, enabled: Bool) => Void;
export declare const setClipsToBounds: (node: Node, clips: Bool) => Void;
export declare const setCornerRadius: (node: Node, radius: F32) => Void;
export declare const setBorderWidth: (node: Node, width: F32) => Void;
export declare const setBorderColor: (node: Node, color: Color) => Void;
export declare const setShadow: (node: Node, color: Color, offset: Rect, radius: F32, opacity: F32) => Void;
export declare const setTag_: (node: Node, tag: I32) => Void;
export declare const getTag_: (node: Node) => I32;
export declare const setAccessLabel: (node: Node, label: Str) => Void;
export declare const layoutIfNeeded: (node: Node) => Void;
export declare const setNeedsLayout: (node: Node) => Void;

export declare const setImageUrl: (node: Node, url: Str) => Void;
export declare const setImageName: (node: Node, name: Str) => Void;
export declare const setSystemImage: (node: Node, sfName: Str) => Void;
export declare const setImageBlob: (node: Node, data: Blob) => Void;
export declare const setContentMode: (node: Node, mode: I32) => Void;
export declare const setTintColor: (node: Node, color: Color) => Void;

export declare const setButtonTitle: (node: Node, title: Str, state: I32) => Void;
export declare const setButtonImage: (node: Node, name: Str, state: I32) => Void;
export declare const setButtonEnabled: (node: Node, enabled: Bool) => Void;
export declare const setSwitchOn: (node: Node, on: Bool, animated: Bool) => Void;
export declare const getSwitchOn: (node: Node) => Bool;
export declare const setSwitchTintColor: (node: Node, color: Color) => Void;
export declare const setSliderValue: (node: Node, value: F32, animated: Bool) => Void;
export declare const getSliderValue: (node: Node) => F32;
