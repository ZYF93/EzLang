export declare const startAnimating: (node: Node) => Void;
export declare const stopAnimating: (node: Node) => Void;

export declare const addTarget: (node: Node, event: I32, handler: ActionHandler) => Void;
export declare const removeTarget: (node: Node, event: I32) => Void;
export declare const setOnTextChanged: (node: Node, handler: TextChangeHandler) => Void;
export declare const setOnReturn: (node: Node, handler: ActionHandler) => Void;
export declare const addTapGesture: (node: Node, taps: I32, handler: ActionHandler) => Void;
