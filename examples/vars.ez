from "std/fmt" import { format, toString };
from "std/io" import { println };

static globalVal = 100;

const main = (): I32 => {
    let count = 10;
    const copy = count;
    count = 20;
    globalVal += 1;
    const args: Str[] = [toString<I32>(value = copy), toString<I32>(value = count), toString<I32>(value = globalVal)];

    println(msg = format(template = "vars: copy={}, count={}, global={}", args = args));
    return copy == 10 && count == 20 && globalVal == 101 ? 0 : 1;
};
