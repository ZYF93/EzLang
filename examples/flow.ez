// flow.ez - 验证 Flow 并发语义分析

const fetch = (url: Str): Str => { return url; };
const readFile = (path: Str): Str => { return path; };
const sleep = (ms: I32): Void => { return; };

const data = flow {
    const a = fetch(url = "https://example.com/a");
    const b = readFile(path = "input.txt");
    sleep(ms = 10);
    const fastest = race(pl = [() => { return 1; }, () => { return 2; }], timeout = 1000);
    return fastest;
};
