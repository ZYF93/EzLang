from "std/io" import { println };
from "std/time" import { sleep };

const main = (): I32 => {
    const value = flow {
        const p = parallel {
            sleep(ms = 10);
            return 7;
        };
        const fastest = race(pl = [
            () => { sleep(ms = 40); return 1; },
            () => { sleep(ms = 5); return 2; },
        ], timeout = 200);
        return p + fastest;
    };

    println(msg = "flow: parallel and race completed");
    return value == 9 ? 0 : 1;
};
